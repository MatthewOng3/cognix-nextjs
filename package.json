{
  "name": "cognix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "npx @biomejs/biome check src/",
    "lint:ci": "npx @biomejs/biome ci src/",
    "lint:fix": "npx @biomejs/biome check --write src/",
    "prepare": "echo skip husky",
    "db:link:dev": "npx supabase link --project-ref hyqbfnuftpxfovgjumsh",
    "db:link:prod": "npx supabase link --project-ref kjkyvrpjogvklnuwevlx",
    "db:pull": "npx supabase db pull --linked",
    "db:push": "npx supabase db push --linked",
    "db:new": "npx supabase migration new"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "npx @biomejs/biome check --write --no-errors-on-unmatched src/",
      "npx @biomejs/biome check --no-errors-on-unmatched src/"
    ],
    "*": [
      "npx @biomejs/biome check --write --no-errors-on-unmatched --files-ignore-unknown=true src/",
      "npx @biomejs/biome check --no-errors-on-unmatched --files-ignore-unknown=true src/"
    ]
  },
  "dependencies": {
    "@blocknote/core": "^0.34.0",
    "@blocknote/mantine": "^0.34.0",
    "@blocknote/react": "^0.34.0",
    "@pinecone-database/pinecone": "^6.1.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@reduxjs/toolkit": "^2.8.2",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@webcontainer/api": "^1.6.1",
    "@webcontainer/snapshot": "^0.1.0",
    "axios": "^1.10.0",
    "class-variance-authority": "^0.7.1",
    "dompurify": "^3.3.0",
    "framer-motion": "^12.23.13",
    "incomplete-json-parser": "^1.1.4",
    "libsodium-wrappers": "^0.7.15",
    "lucide-react": "^0.513.0",
    "next": "^16.1.6",
    "node-ssh": "^13.2.1",
    "octokit": "^5.0.3",
    "radix-ui": "^1.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.1",
    "tailwind-merge": "^3.3.0",
    "vaul": "^1.1.2",
    "zod": "^4.1.5",
    "typescript": "^5.9.3",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^20.19.35",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.1",
    "@eslint/eslintrc": "^3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^15.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "supabase": "^2.51.0"
  },
  "overrides": {
    "yjs": "^13.6.15"
  }
}
